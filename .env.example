# Copy this file to .env and fill in your Anthropic API key.

# LLM — Claude via LiteLLM
CHAT_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-api03-...

# Dummy OpenAI key — required to pass LiteLLM settings validation; not used
OPENAI_API_KEY=dummy-not-used

# Paths for RD-Agent's factor code sandbox
FACTOR_CoSTEER_DATA_FOLDER=git_ignore_folder/factor_implementation_source_data
FACTOR_CoSTEER_DATA_FOLDER_DEBUG=git_ignore_folder/factor_implementation_source_data

# Qlib data directory
QLIB_PROVIDER_URI=~/.qlib/qlib_data/us_data
